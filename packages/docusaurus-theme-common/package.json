{
  "name": "@ianaio/theme-common",
  "version": "3.0.0-alpha.0",
  "description": "Common code for Ianaio themes.",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "sideEffects": [
    "lib/components/Details/*",
    "*.css"
  ],
  "exports": {
    ".": "./lib/index.js",
    "./internal": "./lib/internal.js",
    "./Details": "./lib/components/Details/index.js"
  },
  "scripts": {
    "build": "tsc && node ../../admin/scripts/copyUntypedFiles.js",
    "watch": "run-p -c copy:watch build:watch",
    "build:watch": "tsc --watch",
    "copy:watch": "node ../../admin/scripts/copyUntypedFiles.js --watch",
    "removeThemeInternalReexport": "node removeThemeInternalReexport.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ianaio/ianaio.git",
    "directory": "packages/ianaio-theme-common"
  },
  "license": "Ianaio",
  "dependencies": {
    "@ianaio/mdx-loader": "3.0.0-alpha.0",
    "@ianaio/module-type-aliases": "3.0.0-alpha.0",
    "@ianaio/plugin-content-blog": "3.0.0-alpha.0",
    "@ianaio/plugin-content-docs": "3.0.0-alpha.0",
    "@ianaio/plugin-content-pages": "3.0.0-alpha.0",
    "@ianaio/utils": "3.0.0-alpha.0",
    "@ianaio/utils-common": "3.0.0-alpha.0",
    "@types/history": "^4.7.11",
    "@types/react": "*",
    "@types/react-router-config": "*",
    "clsx": "^1.2.1",
    "parse-numeric-range": "^1.3.0",
    "prism-react-renderer": "^1.3.5",
    "tslib": "^2.6.0",
    "use-sync-external-store": "^1.2.0",
    "utility-types": "^3.10.0"
  },
  "devDependencies": {
    "@ianaio/core": "3.0.0-alpha.0",
    "@ianaio/types": "3.0.0-alpha.0",
    "fs-extra": "^11.1.1",
    "lodash": "^4.17.21"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "engines": {
    "node": ">=16.14"
  }
}
